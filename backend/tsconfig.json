{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",
    "module": "nodenext",
    "target": "esnext",
    "types": ["node"],
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "strict": true,
    "jsx": "react-jsx",
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "esModuleInterop": true,
  },
  "include": ["server.ts", "src/**/*.ts"],
  "exclude": [
    "dist",
    "node_modules",
    "src/**/*.js",
    "src/**/*.js.map",
    "src/**/*.d.ts",
    "src/**/*.d.ts.map",
    "server.js",
    "server.js.map",
    "server.d.ts",
    "server.d.ts.map"
  ]
}
